<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="end"
        android:layout_marginLeft="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:id="@+id/lnrIP"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        >
        <TextView
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tvIP"
        android:layout_marginEnd="5dp"
            android:id = "@+id/tvConnectionStatus"
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content"
            android:textSize="12sp"
            android:text="Disconnected"
            android:textAppearance = "@style/Base.TextAppearance.AppCompat.Medium" />

      <!--  <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="tvConnectionStatus" />-->

        <TextView
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tvPort"
            android:layout_marginEnd="10dp"
            android:id = "@+id/tvIP"
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content"
            android:textSize="12sp"
            android:text="192.168.0.1"
            android:textAppearance = "@style/Base.TextAppearance.AppCompat.Medium" />
        <TextView
            android:text="8081"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:id = "@+id/tvPort"
            android:layout_width = "wrap_content"
            android:layout_height = "wrap_content"
            android:textAppearance = "@style/Base.TextAppearance.AppCompat.Medium"
            android:visibility="gone"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <include android:id="@+id/nodata"
        android:visibility="gone"
        layout="@layout/nodata_layout" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        app:layout_constraintTop_toBottomOf="@+id/lnrIP"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="match_parent"
        android:layout_height="0dp" />

</androidx.constraintlayout.widget.ConstraintLayout>